# Local operational environment (not for public repo)
.claude/memory/
.claude/settings.local.json
.claude/settings.json
.claude/scheduled_tasks.lock
context/

# Paper — PDF regenerated from HTML; canonical version on Zenodo/arXiv
paper/*.pdf

# macOS system files
.DS_Store

# IDE
.idea/

# tracks — local work only (.gitkeep preserves directory structure)
# All session records, digests, and personal work history stay local.
# Only .gitkeep files are committed to preserve directory skeleton.
tracks/**
!tracks/**/
!tracks/**/.gitkeep

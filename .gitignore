# Local operational environment (not for public repo)
.claude/memory/
.claude/settings.local.json
.claude/settings.json
.claude/scheduled_tasks.lock
.claude/goal-quench.active
.claude/goal-quench.pending
.claude/be_last_sync
.claude/worktrees/
.claude-octopus/

# Hub-owner local operations — operator-specific wiring (companion-store route, Gap 1).
# Auto-loaded locally, never public. Backed up to fh-be/hub-owner/ via sync-to-be.sh.
CLAUDE.local.md
context/

# public-surface-audit pattern source — operator-private token patterns (real username, employer, store).
# The skill reads this file; it must never be public (it literally lists the private tokens to hunt for).
.claude/rules/.public-surface-patterns

# Paper — PDF regenerated from HTML; canonical version on Zenodo/arXiv
paper/*.pdf

# Unpublished paper drafts/frameworks — local only. Only completed papers go public (in paper/).
knowledge/shared/harness-core/*_paper_draft.md
knowledge/shared/harness-core/*_paper_framework.md

# macOS system files
.DS_Store

# IDE
.idea/

# tracks — local work only (.gitkeep preserves directory structure)
# All session records, digests, and personal work history stay local.
# Only .gitkeep files are committed to preserve directory skeleton.
tracks/**
!tracks/**/
!tracks/**/.gitkeep

# FC consent lane — the ONLY tracked subtree under tracks/ (v3 federated compounding).
# Writing into tracks/_contrib/ IS the consent act: contributions here are public by intent,
# gated at PR time (public-surface-audit + marketplace-gate Check 5 + ingest contradiction scan).
!tracks/_contrib/
!tracks/_contrib/**

# qasp — company-domain content (kakaopay GHE, payment/insurance). Fully local isolation:
# the project NAME must never reach public FH git, so even its .gitkeep is ignored.
# (sync-to-be.sh already only mirrors _meta/_audit, so fh-be never receives it either.)
/tracks/qasp/
.codex/

# Local skill registry — auto-generated per-machine scan (personal paths). Regenerated each session.
.claude/registry/LOCAL_SKILL_REGISTRY.md

{
  // FH environment context file — auto-generated by install-wizard, can be manually edited
  // Common company · network · Git environment info referenced by all skills
  // Reference: place in .claude/rules/ alongside local_fh_context.md

  "version": "1.0",

  // ── Company environment ─────────────────────────────────────
  "company": {
    "name": "your-company",                              // Company name (for skill prompt context injection)
    "jira_url": "https://jira.your-company.com",        // Jira base URL
    "wiki_url": "https://wiki.your-company.com",        // Wiki base URL
    "ghe_url": "https://github.your-company.com",       // Internal GitHub Enterprise URL
    "slack_workspace": "your-workspace"                 // Slack workspace name
  },

  // ── Network environment ─────────────────────────────────────
  "network": {
    "type": "internal",                                 // "internal" | "vpn" | "external"
    // internal: direct internal network / vpn: via VPN / external: external network

    "mcp_services": {
      "<your-mcp-service>": {
        "status": "active",                             // "active" | "suspended"
        "suspension_note": "",                          // Suspension reason (audit, maintenance, etc.)
        "resume_date": ""                               // Scheduled resume date (YYYY-MM-DD)
      }
    }
  },

  // ── Git / PR environment ────────────────────────────────────
  "git": {
    "org": "your-ghe-org",                              // GHE org (for auto-generating PR URLs)
    "default_base_branch": "develop",                  // PR base default: "develop" | "main"
    "pr_required": true                                 // Whether direct push to main/develop is blocked
  },

  // ── FH install status (auto-recorded by install-wizard) ─────
  "fh": {
    "installed_plugins": ["fh-meta"],
    "install_date": "",                                 // YYYY-MM-DD
    "active_skills": [],                               // List of skills currently in use (optional)
    "custom_keywords": []                              // User-added trigger keywords (optional)
  }
}

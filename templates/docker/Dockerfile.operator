# FH Operator Container (Track 2) — reproducible HEADLESS toolchain.
# Goal: identical grep/sed/jq/bash/node/python/perl everywhere → kills BSD↔GNU WOMBAT
#       (the count_check / phantom-quench gate-drift class). Tools only; NO data/code/auth baked.
# Build (multi-arch for the M6+4090 cluster):
#   docker buildx build --platform linux/arm64,linux/amd64 \
#     -f templates/docker/Dockerfile.operator -t fh-operator:latest .
# Run: see scripts/docker_phase0_verify.sh (mounts forge-harness, runs gates in-container).
#
# Scope: headless/file/gate work (bash · gates · codex exec · agy -p · yt-dlp · node CLIs ·
#        quench/sim dispatch). NOT live-surface (claude-in-chrome / computer-use / Playwright-display
#        are host-bound). NOT GPU serving (that is Track 1, 4090 node, separate image).
FROM node:22-bookworm-slim

# GNU baseline toolchain — the immutability core.
RUN apt-get update && apt-get install -y --no-install-recommends \
      git bash coreutils grep sed gawk jq perl python3 python3-pip \
      ca-certificates curl ripgrep \
    && rm -rf /var/lib/apt/lists/*

# video-ingest Tier3 transcript path (kept updatable; warnings are non-blocking).
RUN pip3 install --no-cache-dir --break-system-packages yt-dlp

# Phase 1 sidecar CLI: codex (npm) — version-pinned for immutability. npm resolves the
# linux-native optional binary per-arch at install, so in-image install is the CORRECT path
# (a host macOS Mach-O codex binary could never run here — mount is a non-starter for native bins).
# agy is host-bound (Mach-O native, no linux mount path); quench/sim are governor Agent dispatches
# (host, option 1) — neither is containerized in Phase 1. AUTH is always runtime-mounted, never baked.
RUN npm install -g @openai/codex@0.139.0

# Phase 1 sidecar CLI #2: agy (Antigravity) — cross-platform Linux build (operator-confirmed:
# Ubuntu/Debian/CentOS + Windows + macOS; the heavy agent is cloud, the local client is cross-platform).
# Installs the arch-correct linux binary to /root/.local/bin (install.sh auto-detects arm64/amd64 →
# multi-arch safe). AUTH is runtime-mounted (~/.gemini), never baked. Headless: agy -p --model.
RUN curl -fsSL https://antigravity.google/cli/install.sh | bash || echo "agy install non-fatal (offline build)"
ENV PATH="/root/.local/bin:${PATH}"

WORKDIR /work/forge-harness
ENV FH_ROOT=/work/forge-harness \
    HUB_DIR=/work/forge-harness \
    BE_DIR=/work/companion-store
ENTRYPOINT ["/bin/bash"]
